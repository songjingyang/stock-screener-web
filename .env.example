# ============================================================================
# 默认零配置即可跑：使用腾讯财经免费接口（无需 token、无需注册）
# ============================================================================

# ----- 本地开发：SQLite -----
# 默认 SQLite，文件会写到 prisma/dev.db，零配置启动
DATABASE_URL="file:./dev.db"

# ----- Vercel 生产：Vercel Postgres（自动注入，无需手动填写）-----
# 在 Vercel Dashboard 创建 Postgres 后会自动注入下列三个变量：
#   POSTGRES_PRISMA_URL          运行时使用（pgbouncer 连接池）
#   POSTGRES_URL_NON_POOLING     prisma db push / migrate 使用（直连）
#   POSTGRES_URL                 普通 SDK 直连备用
# 项目里 scripts/prepare-prisma.js 在 build 时会自动检测并切换 provider。
# 本地若想连远程 Postgres：在 .env 把 DATABASE_URL 设为 postgres:// 协议即可。

# Vercel Cron 鉴权密钥（仅生产部署时配置任意强随机串；本地可留空）
CRON_SECRET=local-dev-secret

# ============================================================================
# 可选：配置后会从腾讯免费源切换到 Tushare Pro（更专业的复权口径，全 A 股覆盖）
# 注册地址：https://tushare.pro/register
# 注意：pro_bar 接口需要 ≥ 2000 积分；不足时会自动降级到 daily（不复权）
# ============================================================================
# TUSHARE_TOKEN=
